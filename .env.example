# LLM 提供商配置（支持多种免费/低成本模型）
# 提供商: openai / minimax / deepseek / zhipu / ollama
LLM_PROVIDER=minimax

# 模型名称
# - MiniMax: abab6.5s-chat (推荐，完全免费)
# - DeepSeek: deepseek-chat
# - 智谱AI: glm-4
# - OpenAI: gpt-4 / gpt-3.5-turbo
LLM_MODEL=abab6.5s-chat

# API Key（根据提供商选择）
# MiniMax: https://api.minimax.chat 注册获取
# DeepSeek: https://platform.deepseek.com 注册获取
# 智谱AI: https://open.bigmodel.cn 注册获取
# OpenAI: https://platform.openai.com 注册获取
LLM_API_KEY=your_api_key_here

# API Base URL（通常不需要修改）
LLM_BASE_URL=https://api.minimax.chat/v1

# API 端点配置（可选，自定义端点）
# OPENAI_ENDPOINT=https://your-custom-openai.com/v1/chat/completions
# MINIMAX_ENDPOINT=https://api.minimax.chat/v1/text/chatcompletion_v2
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/chat/completions
# ZHIPU_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions

# 微信公众号配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_KEY=your_wechat_key_for_url_generation

# 微信公众号 API 端点配置（可选）
# WECHAT_TOKEN_URL=https://api.weixin.qq.com/cgi-bin/token
# WECHAT_DRAFT_URL=https://api.weixin.qq.com/cgi-bin/draft/add
# WECHAT_PUBLISH_URL=https://api.weixin.qq.com/cgi-bin/freepublish/commit
# WECHAT_UPLOAD_URL=https://api.weixin.qq.com/cgi-bin/media/uploadimg

# 数据库配置（可选）
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wine_articles

# Redis配置（可选，用于缓存）
REDIS_HOST=localhost
REDIS_PORT=6379

# 应用配置
NODE_ENV=development
LOG_LEVEL=info
TZ=Asia/Shanghai

# 模拟数据模式（开发调试用）
USE_MOCK_DATA=false

# ===== 数据源配置 =====

# RSS源配置 - 逗号分隔多个URL
# 示例: https://site1.com/rss.xml,https://site2.com/rss.xml
# RSS_SOURCES=https://www.wine-world.com/articlerss/rss.aspx,https://www.decanter.com/feed/

# 聚合数据 API Key (新闻接口)
JUHE_API_KEY=your_juhe_api_key

# 天行数据 API Key (新闻接口)
TIANAPI_KEY=your_tianapi_key

# ===== 网络代理配置（可选）=====

# HTTP/HTTPS 代理，用于解决DNS问题
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ===== 发布配置 =====

# 测试模式 - true只创建草稿，false正式发布
WECHAT_TEST_MODE=true

# 自动发布
WECHAT_AUTO_PUBLISH=true

# ===== 微信公众号RSS源配置 =====

# wewe-rss 服务地址（部署后填入）
# 示例: http://localhost:4000 或 https://your-domain.com
WEWERSS_SERVER=

# 微信公众号RSS源 - 逗号分隔多个URL
# 获取方式: 部署wewe-rss后，扫码授权，在公众号详情页获取RSS链接
# 格式: https://your-wewerss-server.com/feed/user/{biz_id}.xml
WECHAT_RSS_SOURCES=
